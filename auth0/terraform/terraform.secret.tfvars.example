# Copy to terraform.secret.tfvars and fill in real values. NEVER commit the real file.
# Auth0 application (backend API) credentials
be_auth0_client_id     = "YOUR_AUTH0_BACKEND_CLIENT_ID"
be_auth0_client_secret = "YOUR_AUTH0_BACKEND_CLIENT_SECRET"

# Auth0 application used by Terraform to manage the tenant
tf_auth0_client_id     = "YOUR_AUTH0_TERRAFORM_CLIENT_ID"
tf_auth0_client_secret = "YOUR_AUTH0_TERRAFORM_CLIENT_SECRET"
tf_auth0_domain        = "example.us.auth0.com"

# Social / enterprise identity provider credentials
gitlab_application_id  = "YOUR_GITLAB_OAUTH_APP_ID"
gitlab_secret          = "YOUR_GITLAB_OAUTH_SECRET"
github_application_id  = "YOUR_GITHUB_OAUTH_APP_ID"
github_secret          = "YOUR_GITHUB_OAUTH_SECRET"
google_application_id  = "YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"
google_secret          = "GOCSPX-YOUR_GOOGLE_OAUTH_SECRET"

# IAM user used by Auth0 to send email via Amazon SES
auth0_email_iam_access_key_id     = "AKIAXXXXXXXXXXXXXXXX"
auth0_email_iam_secret_access_key = "REPLACE_WITH_SES_IAM_SECRET_ACCESS_KEY"

# Misc integrations
slack_webhook_url = "https://hooks.slack.com/services/REPLACE/WITH/WEBHOOK"
sentry_dsn        = "https://YOUR_SENTRY_KEY@oYOUR_ORG.ingest.sentry.io/YOUR_PROJECT"
