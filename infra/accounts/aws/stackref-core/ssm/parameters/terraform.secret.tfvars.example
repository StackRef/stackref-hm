# Copy to terraform.secret.tfvars and fill in real values. NEVER commit the real file.
# These values are stored as SSM SecureString parameters and consumed by the
# application Lambdas and integrations at runtime.

# AWS IAM Identity Center (SSO) SCIM provisioning endpoint
aws_scim_url   = "https://scim.us-east-1.amazonaws.com/REPLACE/scim/v2"
aws_scim_token = "REPLACE_WITH_SCIM_BEARER_TOKEN"

# Stripe (billing)
stripe_api_key_dev          = "sk_test_YOUR_STRIPE_SECRET_KEY_DEV"
stripe_api_key_prod         = "sk_live_YOUR_STRIPE_SECRET_KEY_PROD"
stripe_endpoint_secret_dev  = "whsec_YOUR_STRIPE_WEBHOOK_SECRET_DEV"
stripe_endpoint_secret_prod = "whsec_YOUR_STRIPE_WEBHOOK_SECRET_PROD"

# OpenAI (used by the AI code-scoring service)
openai_api_key = "sk-YOUR_OPENAI_API_KEY"
