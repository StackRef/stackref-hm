# StackRef HM frontend configuration.
# Copy to `.env.local` (for local dev) or `.env.<env>` and fill in real values.
# All variables are build-time and PUBLIC (they ship in the browser bundle) —
# never put true secrets here.

GENERATE_SOURCEMAP=false

REACT_APP_VERSION=$npm_package_version
REACT_APP_ENVIRONMENT="development"

# --- Auth0 (Single Page Application client) ---
REACT_APP_AUTH0_DOMAIN="auth.example.com"
REACT_APP_AUTH0_CLIENT_ID="YOUR_AUTH0_SPA_CLIENT_ID"

# --- API + realtime WebSocket endpoints ---
REACT_APP_SR_API_URL="https://api.example.com"
REACT_APP_SR_WS_ENABLED="true"
REACT_APP_SR_WS_BASE="wss://ws.example.com"

# --- Analytics (optional) ---
REACT_APP_GTM_CONTAINER_ID=""
REACT_APP_GA_MEASUREMENT_ID=""

# --- Error reporting (optional) ---
REACT_APP_SENTRY_DSN=""
REACT_APP_SENTRY_ENABLED=
REACT_APP_SENTRY_DEBUG=

# --- MUI X Pro license (required for the Pro date/range pickers) ---
# See https://mui.com/x/introduction/licensing/
REACT_APP_MUI_PRO_LICENSE_KEY="YOUR_MUI_PRO_LICENSE_KEY"

# --- Zoom Meeting SDK (optional, for in-app video) ---
REACT_APP_ZOOM_SDK_KEY=
REACT_APP_ZOOM_SDK_SECRET=

# --- Stripe (optional, billing) ---
REACT_APP_STRIPE_PUBLIC_KEY="pk_test_YOURSTRIPEPUBLISHABLEKEY"
REACT_APP_STRIPE_PRICING_TABLE=
